# ============================================================================
# 01_apollo_mnl.R — M1 (attributes), M2 (ASCs), M3 (ASCs + interactions)
# ============================================================================
# Cross-validation of scripts/02_estimate_models.py: same specifications on
# raw attributes -> LL and coefficients should match to ~1e-4.
#
# Expected Python results (2026-07-04):
#   M1 LL = -9850.73   M2 LL = -9755.07   M3 LL = -9733.21
#
# IDENTIFICATION (plan §0.3): never combine full ASCs with attribute betas —
# attributes are constant per item and perfectly collinear with the ASCs.
library(apollo)
source("apollo_config.R")
source("apollo_data_prep.R")
apollo_initialise()
database <- database_first
run_mnl <- function(model_name, beta_vec, fixed, V_fun) {
apollo_control <<- list(
modelName    = model_name,
modelDescr   = model_name,
indivID      = "user_id",
outputDirectory = OUT_DIR,
panelData    = FALSE,
seed         = SEED
)
apollo_beta   <<- beta_vec
apollo_fixed  <<- fixed
apollo_probabilities <<- function(apollo_beta, apollo_inputs,
functionality = "estimate") {
apollo_attach(apollo_beta, apollo_inputs)
on.exit(apollo_detach(apollo_beta, apollo_inputs))
P <- list()
V <- V_fun()
mnl_settings <- list(
alternatives = ALT_CODES,
avail        = setNames(lapply(1:10, function(a)
get(paste0("avail_", a))), names(ALT_CODES)),
choiceVar    = choice,
utilities    = V
)
P[["model"]] <- apollo_mnl(mnl_settings, functionality)
P <- apollo_prepareProb(P, apollo_inputs, functionality)
P
}
apollo_inputs <- apollo_validateInputs()
model <- apollo_estimate(apollo_beta, apollo_fixed,
apollo_probabilities, apollo_inputs)
apollo_modelOutput(model)
apollo_saveOutput(model)
model
}
# ---------------------------------------------------------------------------
# M1 — attributes only
# ---------------------------------------------------------------------------
m1 <- run_mnl(
"APOLLO_M1_attributes",
c(b_price = 0, b_oil = 0, b_freq = 0),
c(),
function() {
V <- list()
for (a in 1:10) {
V[[names(ALT_CODES)[a]]] <-
b_price * get(paste0("price_", a)) +
b_oil   * get(paste0("oil_",   a)) +
b_freq  * get(paste0("freq_",  a))
}
V
}
)
